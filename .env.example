# ========================================
# Flowly Voice API - Mock Configuration
# ========================================
# API HTTP para processar comandos de voz
# Roda sem backend/banco de dados - todos os dados são mockados em memória


# ========================================
# API & Authentication
# ========================================

# Tipo de usuário simulado (admin | user)
# Default: admin
FLOWLY_USER_TYPE=admin

# ID do usuário autenticado (uuid/objectid)
# Se não definido, gera um aleatório
FLOWLY_ME_USER_ID=507f1f77bcf86cd799439011

# CORS Origin (para requisições de frontend)
# Use "*" para permitir qualquer origem (desenvolvimento)
# Use "https://seu-frontend.com" em produção
FLOWLY_CORS_ORIGIN=*


# ========================================
# Mock Data
# ========================================

# Caminho do arquivo de mock data JSON
# Relativo à pasta do projeto
# Em Google Cloud Functions, use /tmp/mock_data.json (ephemeral storage)
FLOWLY_MOCK_DATA_PATH=mock_data.json


# ========================================
# Voice Recognition & Text-to-Speech
# ========================================

# Idioma padrão
FLOWLY_LANGUAGE=pt-BR

# Timeout para escuta (segundos)
FLOWLY_LISTEN_TIMEOUT=5

# Tempo máximo de frase contínua (segundos)
FLOWLY_PHRASE_TIME_LIMIT=10

# Ativar TTS (Text-to-Speech)
FLOWLY_TTS_ENABLED=0

# Taxa de fala TTS (0-500)
FLOWLY_TTS_RATE=175

# Volume TTS (0.0-1.0)
FLOWLY_TTS_VOLUME=1.0

# Modo de texto apenas (desativa microfone)
FLOWLY_TEXT_ONLY=1


# ========================================
# Speech Recognition (Google)
# ========================================

# Threshold de energia para detectar fala (maior = menos sensível)
FLOWLY_SR_ENERGY_THRESHOLD=300

# Ajustar dinamicamente o threshold de energia
FLOWLY_SR_DYNAMIC_ENERGY=True

# Pausa para considerar fim da frase (segundos)
FLOWLY_SR_PAUSE_THRESHOLD=0.8

# Duração de silêncio não-fala (segundos)
FLOWLY_SR_NON_SPEAKING_DURATION=0.5


# ========================================
# Command Parser
# ========================================

# Threshold de match do fuzzy matching (0-100)
# Maior = mais restritivo
# Default: 78 (recomendado para português)
FLOWLY_MATCH_THRESHOLD=78


# ========================================
# Logging & Debug
# ========================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Salvar logs em arquivo
LOG_FILE=

# Diretório para debug/logs
LOG_DIR=logs
